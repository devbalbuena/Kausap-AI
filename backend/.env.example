# ──────────────────────────────────────────────
# Kausap AI — Backend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# Neon Postgres connection string
# Get this from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/kausap_ai?sslmode=require

# JWT secret key — generate a strong random string for production
# Example (run in terminal): python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-a-strong-random-string

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
